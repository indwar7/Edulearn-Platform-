{
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/edutok/:path*",
      "destination": "/edulearn-frontend/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/backend-api/:path*",
      "destination": "http://ec2-65-2-183-7.ap-south-1.compute.amazonaws.com/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "http://ec2-65-2-183-7.ap-south-1.compute.amazonaws.com/socket.io/:path*"
    }
  ]
}
